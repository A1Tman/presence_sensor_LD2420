# Set detected flash size to 4MB to match hardware and avoid warnings
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"

# Use a custom single-app partition table with a larger factory app slot.
# This avoids running out of room while keeping the layout simple.
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# Only build the SSD1306 driver family for the onboard 72x40 OLED.
# CONFIG_U8G2_DISPLAY_DRIVER_ALL is not set
CONFIG_U8G2_DISPLAY_DRIVER_SSD1306=y

# Enable UART driver (already a default in IDF 5.x)
CONFIG_UART_ISR_IN_IRAM=y

# Console over USB-Serial-JTAG (free GPIO20/21 from UART0)
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
# CONFIG_ESP_CONSOLE_NONE is not set
